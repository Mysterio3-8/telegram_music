# Токен от @BotFather (обязательно)
BOT_TOKEN=

# По умолчанию SQLite для разработки. Для прода:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/musicbot

# Токен платёжного провайдера из BotFather для оплаты картой/СБП.
# Пусто → в боте доступна только оплата Telegram Stars.
# PAYMENT_PROVIDER_TOKEN=

# Redis для FSM и брокера Celery. Пусто → FSM в памяти, фоновые задачи выключены.
# REDIS_URL=redis://localhost:6379/0

# Хранилище аудио. По умолчанию локальный каталог storage/.
# Для S3-совместимого (MinIO / R2 / B2) задать все поля:
# S3_ENDPOINT_URL=https://...
# S3_BUCKET=tgmusic
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# Путь к бинарнику chromaprint (fpcalc). Нужен ffmpeg + libchromaprint-tools в системе.
# FPCALC_PATH=fpcalc

# Администраторы бота: Telegram ID через запятую (доступ к /admin и правке треков)
# ADMIN_IDS=123456789,987654321

# Размер пачки аудио для очереди воспроизведения и микса (по умолчанию 5)
# QUEUE_BATCH_SIZE=5

# Обязательная подписка на каналы (TZ §14-17). Пусто в любом поле → канал не проверяется.
# REQUIRED_CHANNEL_1=@tgramuzuka
# REQUIRED_CHANNEL_1_LABEL=📢 ТГ Музыка
# REQUIRED_CHANNEL_2=@zvyagaminus
# REQUIRED_CHANNEL_2_LABEL=🎤 Минусы
# SUBSCRIPTION_CACHE_TTL_MINUTES=60
# Администраторы обходят проверку подписки (по умолчанию false — проверяются наравне со всеми)
# ADMIN_BYPASS_SUBSCRIPTION=true

# Публичный REST API (§27). Секрет JWT; пусто → подписывается bot_token.
# JWT_SECRET=
# JWT_TTL_MINUTES=1440
# CORS origins для Mini App через запятую (пусто → CORS выключен).
# API_CORS_ORIGINS=https://your-mini-app.example.com

# YouTube-импортёр (доп. ТЗ). Cookies — путь к файлу Netscape-формата (yt-dlp),
# только для приватного/возрастного контента; для публичных каналов НЕ нужны.
# Файл держать вне репозитория с правами 600, не коммитить.
# YOUTUBE_COOKIES_PATH=/opt/tg-music-bot/secrets/youtube_cookies.txt
# YOUTUBE_CONCURRENCY=2        # одновременных загрузок (1-5)
# YOUTUBE_MAX_RETRIES=3        # попыток при временной ошибке
# YOUTUBE_CHECK_INTERVAL_DAYS=30

# Импорт из личного Telegram-канала — БЕЗ файлов на диске (tg_file_id-only).
# api_id/api_hash — на https://my.telegram.org (API development tools).
# Сессия создаётся один раз: `python -m app.cli.telegram_login` (интерактивно,
# спросит номер телефона и код). Файл сессии — вне git, права 600, даёт полный
# доступ к аккаунту, как и сам номер телефона.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION_PATH=/opt/tg-music-bot/secrets/telegram_userbot.session
# Приватный чат, куда бот перезаливает трек, чтобы получить свой tg_file_id.
# Пусто → личка первого администратора (ADMIN_IDS) — будет туда прилетать каждый трек.
# TELEGRAM_ARCHIVE_CHAT_ID=
# TELEGRAM_CHANNEL_CHECK_INTERVAL_DAYS=1
# TELEGRAM_CHANNEL_MAX_RETRIES=3
